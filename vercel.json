{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "dist" }
    },
    {
      "src": "api/**/*.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "headers": {
        "X-Content-Type-Options": "nosniff",
        "Referrer-Policy": "strict-origin-when-cross-origin",
        "Permissions-Policy": "camera=(), microphone=(), geolocation=(), payment=()",
        "X-Frame-Options": "SAMEORIGIN"
      },
      "continue": true
    },
    {
      "src": "/public/images/(.*)",
      "headers": { "Cache-Control": "public, max-age=31536000, immutable" },
      "continue": true
    },
    {
      "src": "/src/data/(.*)",
      "headers": { "Cache-Control": "public, max-age=0, must-revalidate" },
      "continue": true
    },
    {
      "src": "/app.js",
      "headers": { "Cache-Control": "public, max-age=0, must-revalidate" },
      "continue": true
    },
    {
      "src": "/styles.css",
      "headers": { "Cache-Control": "public, max-age=0, must-revalidate" },
      "continue": true
    },
    {
      "src": "/public/media/teoyubeworld/pilot-v1/(.*)",
      "headers": { "Cache-Control": "public, max-age=31536000, immutable" },
      "continue": true
    },
    {
      "src": "/public/media/teoyubeworld/pilot-v1/(.*manifest.*\\.json)",
      "headers": { "Cache-Control": "public, max-age=0, must-revalidate" },
      "continue": true
    },
    {
      "src": "/api/promises/seed",
      "dest": "/api/promises/seed.js"
    },
    {
      "src": "/api/youtube/teoyube",
      "dest": "/api/youtube/teoyube.js"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/media/teoyubeworld/pilot-v1/(.*)",
      "dest": "/public/media/teoyubeworld/pilot-v1/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
