  "apiRoutePlan": [
    { "method": "GET", "path": "/api/words", "purpose": "List Teoyube words." },
    { "method": "GET", "path": "/api/words/[word]", "purpose": "Fetch one Teoyube word." },
    { "method": "GET", "path": "/api/clusters", "purpose": "List Promise Clusters." },
    { "method": "GET", "path": "/api/clusters/[id]", "purpose": "Fetch one Promise Cluster." },
    { "method": "GET", "path": "/api/prayers", "purpose": "List prayer templates." },
    { "method": "GET", "path": "/api/prayers/[id]", "purpose": "Fetch one prayer template." },
    { "method": "GET", "path": "/api/daily-word", "purpose": "Return the daily focus word." },
    { "method": "POST", "path": "/api/journal", "purpose": "Create a journal entry." },
    { "method": "GET", "path": "/api/journal", "purpose": "List journal entries." },
    { "method": "POST", "path": "/api/ai/companion", "purpose": "Generate companion response." },
    { "method": "POST", "path": "/api/ai/prayer", "purpose": "Generate prayer response." },
    { "method": "POST", "path": "/api/assessment", "purpose": "Submit profile or archetype assessment." }
  ],
  "coreUtilityFunctions": [
    {
      "file": "lib/dailyWord.ts",
      "name": "getDailyWord",
      "code": "export function getDailyWord(words: any[]) {\n  const today = new Date().toISOString().slice(0, 10);\n  const index =\n    today.split(\"\").reduce((sum, char) => sum + char.charCodeAt(0), 0) %\n    words.length;\n\n  return words[index];\n}"
    },
    {
      "file": "lib/prayerEngine.ts",
      "name": "buildPrayer",
      "code": "export function buildPrayer(words: any[]) {\n  const meanings = words.map((w) => w.meaning).join(\" -> \");\n\n  return {\n    sequence: words.map((w) => w.word),\n    meaningFlow: meanings,\n    prayer: `Father, lead me through ${meanings.toLowerCase()} according to Your promise.`\n  };\n}"
    },
    {
      "file": "lib/recommendations.ts",
      "name": "recommendCluster",
      "code": "export function recommendCluster(userNeed: string) {\n  const need = userNeed.toLowerCase();\n\n  if (need.includes(\"peace\")) return \"Peace & Protection\";\n  if (need.includes(\"healing\")) return \"Healing & Restoration\";\n  if (need.includes(\"wisdom\")) return \"Light & Revelation\";\n  if (need.includes(\"purpose\")) return \"Calling & Purpose\";\n  if (need.includes(\"identity\")) return \"Sonship & Belonging\";\n\n  return \"Calling & Purpose\";\n}"
    }
  ],
